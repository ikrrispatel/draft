{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "qa.schema.json",
    "title": "Draft QA Agent Output",
    "description": "Output schema for the QA agent: wedge validation, violations, conflicts, revision requests, reruns, and pass status.",
    "type": "object",
    "properties": {
        "wedge_is_single": {
            "type": "boolean",
            "description": "Whether the Vision agent produced exactly one wedge."
        },
        "violations": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "string",
                        "description": "Machine-readable violation code (e.g. 'FEATURE_COUNT_MISMATCH')."
                    },
                    "message": {
                        "type": "string",
                        "description": "Human-readable violation description."
                    },
                    "field_path": {
                        "type": "string",
                        "description": "Dot-notation path to the violating field (e.g. 'scope.features')."
                    },
                    "target_agent": {
                        "type": "string",
                        "enum": [
                            "vision",
                            "scope",
                            "distribution",
                            "architecture"
                        ],
                        "description": "Agent responsible for fixing this violation."
                    }
                },
                "required": [
                    "code",
                    "message",
                    "field_path",
                    "target_agent"
                ],
                "additionalProperties": false
            },
            "description": "List of constraint violations detected."
        },
        "conflicts": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "description": "Human-readable conflict description."
                    },
                    "related_fields": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Dot-notation paths to the conflicting fields."
                    },
                    "target_agent": {
                        "type": "string",
                        "enum": [
                            "vision",
                            "scope",
                            "distribution",
                            "architecture"
                        ],
                        "description": "Agent best positioned to resolve this conflict."
                    }
                },
                "required": [
                    "message",
                    "related_fields",
                    "target_agent"
                ],
                "additionalProperties": false
            },
            "description": "List of cross-agent consistency conflicts detected."
        },
        "revision_requests": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "target_agent": {
                        "type": "string",
                        "enum": [
                            "vision",
                            "scope",
                            "distribution",
                            "architecture"
                        ],
                        "description": "Agent to rerun."
                    },
                    "instruction": {
                        "type": "string",
                        "description": "Specific instruction for the targeted rerun."
                    }
                },
                "required": [
                    "target_agent",
                    "instruction"
                ],
                "additionalProperties": false
            },
            "description": "Targeted rerun requests generated by QA. Max 1 per agent."
        },
        "reruns_triggered": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of agent names that were actually rerun."
        },
        "pass": {
            "type": "boolean",
            "description": "True if no unresolved violations remain after reruns."
        }
    },
    "required": [
        "wedge_is_single",
        "violations",
        "conflicts",
        "revision_requests",
        "reruns_triggered",
        "pass"
    ],
    "additionalProperties": false
}